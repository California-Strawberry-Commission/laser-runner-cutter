{
  // See https://code.visualstudio.com/docs/debugtest/tasks#vscode
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "[ros2] build workspace",
      "detail": "Build ROS 2 workspace",
      "type": "shell",
      "command": "source /opt/ros/${ROS_DISTRO}/setup.sh && colcon build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "[ros2] build package",
      "detail": "Build single ROS 2 package",
      "type": "shell",
      "command": "source /opt/ros/${ROS_DISTRO}/setup.sh && colcon build --packages-select ${input:package}",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "[ros2] launch all",
      "detail": "Run all of the nodes in the workspace",
      "type": "shell",
      "command": "${workspaceFolder}/docker/build_and_run.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "group": {
        "kind": "test",
        "isDefault": false
      }
    },
    {
      "label": "[ros2] test workspace",
      "detail": "Run all unit tests and show results.",
      "type": "shell",
      "command": "colcon test && colcon test-result --all",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ],
  "inputs": [
    {
      "id": "package",
      "type": "promptString",
      "description": "Package name",
      "default": "my_package"
    },
    {
      "id": "launch_file",
      "type": "promptString",
      "description": "Launch file name",
      "default": "launch.py"
    }
  ]
}